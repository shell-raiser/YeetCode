{
  "manifest_version": 3,
  "name": "YeetCode",
  "description": "Save LeetCode code and notes to a GitHub repository on button click.",
  "version": "1.0",
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_title": "YeetCode Options",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/problems/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pageBridge.js", "catcodeSmall.svg"],
      "matches": ["*://leetcode.com/*"]
    }
  ]
}
